  <script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=6a0204edde30195e44a50e08" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script is:inline src="/js/webflow.js" type="text/javascript"></script>
  <script is:inline>
    (() => {
      const featurePanel = document.querySelector(".s-ider-box-content");
      const sliderNav = featurePanel?.querySelector(".slider-nav");
      const featureKeys = ["rail", "convenience", "continuity"];

      if (!featurePanel || !sliderNav) return;

      const syncFeatureImage = () => {
        const dots = Array.from(sliderNav.querySelectorAll(".w-slider-dot"));
        const activeIndex = Math.max(0, dots.findIndex((dot) => dot.classList.contains("w-active")));
        featurePanel.dataset.featureBg = featureKeys[activeIndex] || featureKeys[0];
      };

      syncFeatureImage();
      new MutationObserver(syncFeatureImage).observe(sliderNav, {
        attributes: true,
        childList: true,
        subtree: true,
        attributeFilter: ["class"],
      });
    })();
  </script>
