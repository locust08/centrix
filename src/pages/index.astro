      { id: "st10", typeGroup: "ST", type: "ST10", page: 10, pdf: "/files/Type-ST-Insert-260130.pdf#page=10", beds: 1, baths: 1, size: "577 sq ft", level: "Level 3A-10", category: "studio", label: "Studio" },
      { id: "st11", typeGroup: "ST", type: "ST11", page: 11, pdf: "/files/Type-ST-Insert-260130.pdf#page=11", beds: 1, baths: 1, size: "604 sq ft", level: "Level 3A-10", category: "studio", label: "Studio" },
      { id: "st12", typeGroup: "ST", type: "ST12", page: 12, pdf: "/files/Type-ST-Insert-260130.pdf#page=12", beds: 2, baths: 2, size: "608 sq ft", level: "Level 3A-10", category: "dual-key", label: "Dual Key" },
      { id: "st13", typeGroup: "ST", type: "ST13", page: 13, pdf: "/files/Type-ST-Insert-260130.pdf#page=13", beds: 2, baths: 2, size: "916 sq ft", level: "Level 3A-10", category: "dual-key", label: "Dual Key", recommended: true },
      { id: "st14", typeGroup: "ST", type: "ST14", page: 14, pdf: "/files/Type-ST-Insert-260130.pdf#page=14", beds: 2, baths: 1, size: "720 sq ft", level: "Level 3A-10", category: "2-bedroom", label: "2 Bedroom", recommended: true },
      { id: "st15", typeGroup: "ST", type: "ST15", page: 15, pdf: "/files/Type-ST-Insert-260130.pdf#page=15", beds: 2, baths: 2, size: "1,193 sq ft", level: "Level 3A-10", category: "dual-key", label: "Dual Key" },
      { id: "st16", typeGroup: "ST", type: "ST16", page: 16, pdf: "/files/Type-ST-Insert-260130.pdf#page=16", beds: 2, baths: 2, size: "637 sq ft", level: "Level 3A-10", category: "dual-key", label: "Dual Key" },
      { id: "st17", typeGroup: "ST", type: "ST17", page: 17, pdf: "/files/Type-ST-Insert-260130.pdf#page=17", beds: 2, baths: 2, size: "787 sq ft", level: "Level 3A-10", category: "dual-key", label: "Dual Key" },
      { id: "st18", typeGroup: "ST", type: "ST18", page: 18, pdf: "/files/Type-ST-Insert-260130.pdf#page=18", beds: 1, baths: 1, size: "802 sq ft", level: "Level 3A-10", category: "studio", label: "1 Bedroom" }
    ];

    const layoutCopy = {
      studio: {
        title: "Studio / 1BR Layouts",
        summary: "Compare compact S layouts on upper levels with ST layouts from the podium range, then open the exact floorplan page."
      },
      "dual-key": {
        title: "Dual Key Layouts",
        summary: "Flexible dual-key options grouped by S and ST type for stay-and-rent or managed rental planning."
      },
      "2-bedroom": {
        title: "2 Bedroom Layouts",
        summary: "Browse 2-bedroom options by toilet count, type series, level range, and PDF page."
      },
      "3-bedroom": {
        title: "3 Bedroom Layouts",
        summary: "The 3-bedroom choices are in S Type only, with larger footprints for owner-stay planning."
      }
    };

    const layoutShowcaseIds = {
      studio: ["s8", "s9", "s5", "s11a", "st4", "st9"],
      "dual-key": ["s3", "s6", "st6", "st13"],
      "2-bedroom": ["s7", "s19", "st8", "st14"],
      "3-bedroom": ["s1", "s4"]
    };

    const layoutShowcaseOrder = Object.values(layoutShowcaseIds).flat();

    const explorer = document.querySelector("[data-layout-explorer]");
    if (explorer) {
      let activeCategory = "studio";
      let activeType = "all";
      let activeBath = "all";
      let activeLayoutId = null;

      const categoryButtons = explorer.querySelectorAll("[data-category]");
      const typeButtons = explorer.querySelectorAll("[data-type-filter]");
      const bathButtons = explorer.querySelectorAll("[data-bath-filter]");
      const title = explorer.querySelector("[data-layout-title]");
      const summary = explorer.querySelector("[data-layout-summary]");
      const count = explorer.querySelector("[data-layout-count]");
      const grid = explorer.querySelector("[data-layout-grid]");
      const detail = explorer.querySelector("[data-layout-detail]");
      const chipLabels = new WeakMap();

      const setActiveButton = (buttons, attr, value) => {
        buttons.forEach((button) => {
          const isActive = button.getAttribute(attr) === value;
          button.classList.toggle("is-active", isActive);
          if (button.hasAttribute("aria-pressed")) {
            button.setAttribute("aria-pressed", String(isActive));
          }
          if (button.hasAttribute("aria-selected")) {
            button.setAttribute("aria-selected", String(isActive));
          }
        });
      };

      const getCategoryLayouts = () => {
        const showcaseIds = layoutShowcaseIds[activeCategory] || [];
        return showcaseIds
          .map((id) => centrixLayouts.find((layout) => layout.id === id))
          .filter(Boolean);
      };

      const matchesType = (layout, type = activeType) => type === "all" || layout.typeGroup === type;

      const matchesBath = (layout, bath = activeBath) => bath === "all" || String(layout.baths) === bath;

      const sortLayouts = (layouts) => layouts.sort((a, b) => {
        return layoutShowcaseOrder.indexOf(a.id) - layoutShowcaseOrder.indexOf(b.id);
      });

      const getFilteredLayouts = () => sortLayouts(getCategoryLayouts()
        .filter((layout) => activeType === "all" || layout.typeGroup === activeType)
        .filter((layout) => activeBath === "all" || String(layout.baths) === activeBath));

      const getOptionCount = (axis, value) => getCategoryLayouts().filter((layout) => {
        const type = axis === "type" ? value : activeType;
        const bath = axis === "bath" ? value : activeBath;
        return matchesType(layout, type) && matchesBath(layout, bath);
      }).length;

      const updateFilterButtons = (buttons, attr, activeValue, axis) => {
        buttons.forEach((button) => {
          const value = button.getAttribute(attr);
          const count = getOptionCount(axis, value);
          const isActive = value === activeValue;
          const baseLabel = chipLabels.get(button) || button.textContent.trim();

          chipLabels.set(button, baseLabel.replace(/\s+\(\d+\)$/, ""));
          button.textContent = `${chipLabels.get(button)} (${count})`;
          button.disabled = !isActive && count === 0;
          button.setAttribute("aria-disabled", String(button.disabled));
        });

        setActiveButton(buttons, attr, activeValue);
      };

      const renderDetail = (layout) => {
        if (!layout) {
          detail.innerHTML = `
            <div class="layout-empty-state">
              <h4>No layout selected</h4>
              <p>Choose a valid type and toilet filter to view a curated layout.</p>
            </div>
          `;
          return;
        }

        const imageName = encodeURIComponent(layout.type);
        detail.innerHTML = `
          <div class="layout-detail-media">
            <img src="/images/Category/${imageName}.png" loading="lazy" alt="${layout.type} floorplan layout">
          </div>
          <div class="layout-detail-copy">
            <div class="layout-detail-heading">
              <span>${layout.typeGroup} Type</span>
              <h4>${layout.type}</h4>
              <p>${layout.beds} Bedroom · ${layout.baths} Toilet</p>
            </div>
            <div class="layout-detail-meta">
              <span>${layout.label}</span>
              <span>${layout.size}</span>
              <span>${layout.level}</span>
              <span>PDF Page ${layout.page}</span>
            </div>
            <div class="layout-detail-actions">
              <a href="${layout.pdf}" target="_blank" rel="noopener" class="black-button layout-pdf-button w-inline-block">
                <div class="button-text-wrap">
                  <div class="button-front-text">View PDF page</div>
                  <div class="button-hidden-text">View PDF page</div>
                </div>
              </a>
              <a href="#Contact" class="white-button layout-contact-button w-inline-block">
                <div class="button-text-wrap">
                  <div class="white-front-text">Register Interest</div>
                  <div class="white-hidden-text">Register Interest</div>
                </div>
              </a>
            </div>
          </div>
        `;
      };

      const render = () => {
        const copy = layoutCopy[activeCategory];
        const layouts = getFilteredLayouts();
        if (!layouts.some((layout) => layout.id === activeLayoutId)) {
          activeLayoutId = layouts[0]?.id || null;
        }

        const selectedLayout = layouts.find((layout) => layout.id === activeLayoutId);
        title.textContent = copy.title;
        summary.textContent = copy.summary;
        count.textContent = layouts.length
          ? `${layouts.length} curated layout${layouts.length === 1 ? "" : "s"}`
          : "No layouts found";
        setActiveButton(categoryButtons, "data-category", activeCategory);
        updateFilterButtons(typeButtons, "data-type-filter", activeType, "type");
        updateFilterButtons(bathButtons, "data-bath-filter", activeBath, "bath");

        grid.innerHTML = layouts.length ? layouts.map((layout) => `
          <button class="layout-card${layout.recommended ? " is-recommended" : ""}${layout.id === activeLayoutId ? " is-active" : ""}" type="button" data-layout-id="${layout.id}" aria-pressed="${layout.id === activeLayoutId}">
            <h4>${layout.type}</h4>
            <div class="layout-card-stats">
              <span aria-label="${layout.beds} Bedroom">${layout.beds}<img src="/images/cdsdaewqec.svg" alt="" loading="lazy"></span>
              <span aria-label="${layout.baths} Toilet">${layout.baths}<img src="/images/toilet.svg" alt="" loading="lazy"></span>
            </div>
          </button>
        `).join("") : `
          <div class="layout-empty-state">
            <h4>No matching layout</h4>
            <p>There is no ${copy.title.toLowerCase()} option for this toilet/type filter in the current S and ST PDFs.</p>
          </div>
        `;

        renderDetail(selectedLayout);
      };

      categoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeCategory = button.getAttribute("data-category");
          activeType = "all";
          activeBath = "all";
          activeLayoutId = null;
          render();
        });
      });

      typeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeType = button.getAttribute("data-type-filter");
          activeLayoutId = null;
          render();
        });
      });

      bathButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeBath = button.getAttribute("data-bath-filter");
          activeLayoutId = null;
          render();
        });
      });

      grid.addEventListener("click", (event) => {
        const button = event.target.closest("[data-layout-id]");
        if (!button) return;
        activeLayoutId = button.getAttribute("data-layout-id");
        render();
      });

      render();
    }
  </script>
