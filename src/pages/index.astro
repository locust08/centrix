        const copy = layoutCopy[activeCategory];
        const layouts = getFilteredLayouts();
        const visibleLayouts = layouts.slice(0, 3);
        title.textContent = copy.title;
        summary.textContent = copy.summary;
        count.textContent = visibleLayouts.length
          ? `Top ${visibleLayouts.length} pick${visibleLayouts.length === 1 ? "" : "s"}`
          : "No layouts found";
        setActiveButton(categoryButtons, "data-category", activeCategory);
        setActiveButton(typeButtons, "data-type-filter", activeType);
        setActiveButton(bathButtons, "data-bath-filter", activeBath);

        grid.innerHTML = visibleLayouts.length ? visibleLayouts.map((layout) => `
          <article class="layout-card${layout.recommended ? " is-recommended" : ""}">
            <div class="layout-card-topline">
              <span>${layout.typeGroup} Type</span>
              ${layout.recommended ? "<strong>Best pick</strong>" : ""}
            </div>
            <h4>${layout.type}</h4>
            <div class="layout-card-stats">
              <span>${layout.beds} Bedroom</span>
              <span>${layout.baths} Toilet</span>
            </div>
            <dl class="layout-card-meta">
              <div><dt>Size</dt><dd>${layout.size}</dd></div>
              <div><dt>Level</dt><dd>${layout.level}</dd></div>
              <div><dt>PDF</dt><dd>Page ${layout.page}</dd></div>
            </dl>
            <button class="layout-card-button" type="button" data-layout-id="${layout.id}">View Detail</button>
          </article>
        `).join("") : `
          <div class="layout-empty-state">
            <h4>No matching layout</h4>
            <p>There is no ${copy.title.toLowerCase()} option for this toilet/type filter in the current S and ST PDFs.</p>
          </div>
        `;

        const selectedLayout = visibleLayouts.find((layout) => layout.id === activeLayoutId);
        renderDetail(selectedLayout);
      };

      categoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeCategory = button.getAttribute("data-category");
          activeType = "all";
          activeBath = "all";
          activeLayoutId = null;
          render();
        });
      });

      typeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeType = button.getAttribute("data-type-filter");
          activeLayoutId = null;
          render();
        });
      });

      bathButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeBath = button.getAttribute("data-bath-filter");
          activeLayoutId = null;
          render();
        });
      });

      grid.addEventListener("click", (event) => {
        const button = event.target.closest("[data-layout-id]");
        if (!button) return;
        activeLayoutId = button.getAttribute("data-layout-id");
        render();
        detail.scrollIntoView({ behavior: "smooth", block: "nearest" });
      });

      detail.addEventListener("click", (event) => {
        if (!event.target.closest("[data-close-detail]")) return;
        activeLayoutId = null;
        render();
      });

      render();
    }
  </script>
